}

// ══════════════════════════════════════════════════════════
// MOUSE EVENTS ON CANVAS
// ══════════════════════════════════════════════════════════
// Drag state for select tool
let dragObj=null, dragStartPos=null, dragObjOrigin=null;

drawSvg.addEventListener('mousedown', e=>{
  if(e.button!==0) return;
  const pos = svgPos(e);

  if(currentTool==='select'){
    const target = e.target.closest('[data-oid]');
    if(target){
      const id = parseInt(target.dataset.oid);
      selectObject(id);
      // start drag
      dragObj = objects.find(o=>o.id===id);
      dragStartPos = pos;
      dragObjOrigin = JSON.parse(JSON.stringify(dragObj));
      e.preventDefault();
    } else {
      selectObject(null);
    }
    return;
  }

  if(currentTool==='poly'){
    // handled in click
    return;
  }

  // line / rect / circle
  drawing = true;
  drawStart = pos;
  e.preventDefault();
});

drawSvg.addEventListener('mousemove', e=>{
  const pos = svgPos(e);
  setStatus(`x: ${pos.x.toFixed(1)}  y: ${pos.y.toFixed(1)}`);

  // Select drag
  if(currentTool==='select' && dragObj && dragStartPos){
    const dx = pos.x - dragStartPos.x;
    const dy = pos.y - dragStartPos.y;
    const o = dragObjOrigin;
    if(dragObj.type==='line'){dragObj.x1=o.x1+dx;dragObj.y1=o.y1+dy;dragObj.x2=o.x2+dx;dragObj.y2=o.y2+dy;}
    else if(dragObj.type==='rect'||dragObj.type==='circle'){dragObj.x1=o.x1+dx;dragObj.y1=o.y1+dy;dragObj.x2=o.x2+dx;dragObj.y2=o.y2+dy;}
    else if(dragObj.type==='poly'){dragObj.pts=o.pts.map(p=>({x:p.x+dx,y:p.y+dy}));}
    renderObject(dragObj);
    return;
  }

  if(!drawing || currentTool==='poly') return;

  // rubber-band preview
  if(tempEl){tempEl.remove();tempEl=null;}
  const p1=drawStart, p2=pos;

  if(currentTool==='line'){
    tempEl=mkEl('line',{x1:p1.x,y1:p1.y,x2:p2.x,y2:p2.y,stroke:activeColor,'stroke-width':currentProps.sw,fill:'none','stroke-dasharray':'1.5 1','stroke-linecap':'round'});
  } else if(currentTool==='rect'){
    const x=Math.min(p1.x,p2.x),y=Math.min(p1.y,p2.y),w=Math.abs(p2.x-p1.x),h=Math.abs(p2.y-p1.y);
    tempEl=mkEl('rect',{x,y,width:w,height:h,stroke:activeColor,'stroke-width':currentProps.sw,fill:activeColor,'fill-opacity':currentProps.fillOpacity,'stroke-dasharray':'1.5 1',rx:currentProps.rx,ry:currentProps.rx});
  } else if(currentTool==='circle'){
    const cx=(p1.x+p2.x)/2,cy=(p1.y+p2.y)/2,rx=Math.abs(p2.x-p1.x)/2,ry=Math.abs(p2.y-p1.y)/2;
    tempEl=mkEl('ellipse',{cx,cy,rx,ry,stroke:activeColor,'stroke-width':currentProps.sw,fill:activeColor,'fill-opacity':currentProps.fillOpacity,'stroke-dasharray':'1.5 1'});
  }
  if(tempEl) tempLayer.appendChild(tempEl);
});

drawSvg.addEventListener('mouseup', e=>{
  if(e.button!==0) return;

  // End drag
  if(currentTool==='select' && dragObj){
    dragObj=null;dragStartPos=null;dragObjOrigin=null;
    return;
  }

  if(!drawing || currentTool==='poly') return;
  drawing=false;
  if(tempEl){tempEl.remove();tempEl=null;}

  const pos=svgPos(e);
  const p1=drawStart, p2=pos;
  const dist=Math.hypot(p2.x-p1.x,p2.y-p1.y);
  if(dist<0.5){drawStart=null;return;}

  if(currentTool==='line'){
    addObject('line',{x1:p1.x,y1:p1.y,x2:p2.x,y2:p2.y});
  } else if(currentTool==='rect'){
    addObject('rect',{x1:p1.x,y1:p1.y,x2:p2.x,y2:p2.y});
  } else if(currentTool==='circle'){
    addObject('circle',{x1:p1.x,y1:p1.y,x2:p2.x,y2:p2.y});
  }
  drawStart=null;
});

// ── Polygon tool ──
drawSvg.addEventListener('click', e=>{
  if(currentTool!=='poly') return;
  const pos=svgPos(e);

  // double click = finish
  if(e.detail===2){
    finishPoly();
    return;
  }

  polyPts.push(pos);

  // draw rubber lines
  polyTempLines.forEach(l=>l.remove());
  polyTempLines=[];
  if(polyPts.length>1){
    for(let i=1;i<polyPts.length;i++){
      const l=mkEl('line',{x1:polyPts[i-1].x,y1:polyPts[i-1].y,x2:polyPts[i].x,y2:polyPts[i].y,stroke:activeColor,'stroke-width':currentProps.sw,'stroke-dasharray':'1.5 1','stroke-linecap':'round'});
      tempLayer.appendChild(l);
      polyTempLines.push(l);
    }
  }
  // dot at each point
  const dot=mkEl('circle',{cx:pos.x,cy:pos.y,r:0.8,fill:activeColor});
  tempLayer.appendChild(dot);
  polyTempLines.push(dot);
});

drawSvg.addEventListener('dblclick', e=>{
  if(currentTool==='poly' && polyPts.length>=2){
    finishPoly();
  }
});

drawSvg.addEventListener('contextmenu', e=>{
  e.preventDefault();
  if(currentTool==='poly') cancelTemp();
});

function finishPoly(){
  if(polyPts.length<2){cancelTemp();return;}
  const pts=[...polyPts];
  cancelTemp();
  addObject('poly',{pts});
}

// ── Mouse move for poly rubber ──
drawSvg.addEventListener('mousemove', e=>{
  if(currentTool!=='poly'||polyPts.length===0) return;
  const pos=svgPos(e);
  // remove last rubber if exists
  if(tempEl){tempEl.remove();tempEl=null;}
  const last=polyPts[polyPts.length-1];
  tempEl=mkEl('line',{x1:last.x,y1:last.y,x2:pos.x,y2:pos.y,stroke:activeColor,'stroke-width':currentProps.sw,'stroke-dasharray':'1 1.5',opacity:'0.5'});
  tempLayer.appendChild(tempEl);
}, {capture:false});

// keyboard shortcuts
document.addEventListener('keydown', e=>{
  if(document.activeElement.tagName==='INPUT'||document.activeElement.tagName==='TEXTAREA'||document.activeElement.tagName==='SELECT') return;
  if(e.key==='v'||e.key==='V') setTool('select');
  if(e.key==='l'||e.key==='L') setTool('line');
  if(e.key==='r'||e.key==='R') setTool('rect');
  if(e.key==='c'||e.key==='C') setTool('circle');
  if(e.key==='p'||e.key==='P') setTool('poly');
  if(e.key==='Escape') cancelTemp();
  if((e.key==='Delete'||e.key==='Backspace') && currentTool==='select') deleteSelected();
  if(e.ctrlKey && e.key==='z'){e.preventDefault();undo();}
  if(e.key==='Enter' && currentTool==='poly' && polyPts.length>=2) finishPoly();
});

// ══════════════════════════════════════════════════════════
// EXPORT DRAWER → SVG STRING
// ══════════════════════════════════════════════════════════

// Convert absolute px coords (0-100 viewbox) to relative expressions
// using pw/ph variables for PLANBAZN
function toRelX(x){ return `\${pw*${(x/100).toFixed(4)}}`; }
function toRelY(y){ return `\${ph*${(y/100).toFixed(4)}}`; }
function toRelR(r, dim){ return `\${${dim}*${(r/100).toFixed(4)}}`; }

function objectToSvgString(obj){
  const c = '${c}';
  const sw = obj.sw;
  const fillAttr = obj.fillOpacity>0 ? ` fill="${c}${Math.round(obj.fillOpacity*255).toString(16).padStart(2,'0')}"` : ` fill="none"`;
  const strokeAttr = ` stroke="${c}" stroke-width="${sw}"`;

  if(obj.type==='line'){
    return `<line x1="${toRelX(obj.x1)}" y1="${toRelY(obj.y1)}" x2="${toRelX(obj.x2)}" y2="${toRelY(obj.y2)}" stroke="${c}" stroke-width="${sw}" stroke-linecap="round"/>`;
  }
  if(obj.type==='rect'){
    const x=Math.min(obj.x1,obj.x2), y=Math.min(obj.y1,obj.y2);
    const w=Math.abs(obj.x2-obj.x1), h=Math.abs(obj.y2-obj.y1);
    const rxAttr = obj.rx>0 ? ` rx="${obj.rx}" ry="${obj.rx}"` : '';
    return `<rect x="${toRelX(x)}" y="${toRelY(y)}" width="${toRelX(w).replace('${pw*','${pw*')}" height="${toRelY(h).replace('${ph*','${ph*')}"${rxAttr}${strokeAttr}${fillAttr}/>`;
  }
  if(obj.type==='circle'){
    const cx=(obj.x1+obj.x2)/2, cy=(obj.y1+obj.y2)/2;
    const rx=Math.abs(obj.x2-obj.x1)/2, ry=Math.abs(obj.y2-obj.y1)/2;
    if(Math.abs(rx-ry)<0.5){
      return `<circle cx="${toRelX(cx)}" cy="${toRelY(cy)}" r="${toRelR(rx,'pw')}"${strokeAttr}${fillAttr}/>`;
    }
    return `<ellipse cx="${toRelX(cx)}" cy="${toRelY(cy)}" rx="${toRelR(rx,'pw')}" ry="${toRelR(ry,'ph')}"${strokeAttr}${fillAttr}/>`;
  }
  if(obj.type==='poly'){
    const d = roundedPolygonPath(
      obj.pts.map(p=>({x:p.x/100,y:p.y/100})),
      obj.rx/100
    );
    // Convert numeric coords to template expressions
    const dExpr = d.replace(/(-?\d+\.?\d*),(-?\d+\.?\d*)/g, (m,x,y)=>{
      return `\${(pw*${parseFloat(x).toFixed(4)}).toFixed(2)},\${(ph*${parseFloat(y).toFixed(4)}).toFixed(2)}`;
    });
    return `<path d="${dExpr}" stroke-linejoin="round" stroke-linecap="round"${strokeAttr}${fillAttr}/>`;
  }
  return '';
}

function generateDrawBody(){
  if(!objects.length) return '<!-- Keine Objekte -->'; 
  return objects.map(o=>objectToSvgString(o)).filter(Boolean).join('\n    ');
}

function sendToTester(){
  if(!objects.length){setStatus('Nichts zu senden — zeichne zuerst etwas');return;}
  const body = generateDrawBody();
  document.getElementById('code-input').value = body;
  switchTab('tester');
  schedulePreview();
  setStatus('An Tester gesendet');
}

function loadFromDrawer(){
  sendToTester();
}

// ══════════════════════════════════════════════════════════
// TESTER / PREVIEW
// ══════════════════════════════════════════════════════════
let previewTimer = null;
function schedulePreview(){ clearTimeout(previewTimer); previewTimer=setTimeout(renderPreview,300); }

function renderPreview(){
  const code = document.getElementById('code-input').value.trim();
  const area = document.getElementById('preview-area');
  area.innerHTML='';
  if(!code){ area.innerHTML='<div style="color:var(--muted);font-size:10px;">Kein Code eingegeben</div>'; return; }

  const sizes = [
    {label:'48×48 (Liste)', w:48, h:48},
    {label:'80×80 (Vorschau)', w:80, h:80},
    {label:'120×80 (Quer)', w:120, h:80},
    {label:'160×160 (Groß)', w:160, h:160},
  ];

  let hasError = false;
  PREVIEW_COLORS.slice(0,4).forEach(previewColor=>{
    sizes.forEach(sz=>{
      let svgContent;
      try{
        const drawFn = new Function('c','pw','ph', `return \`${code}\``);
        svgContent = drawFn(previewColor, sz.w, sz.h);
      } catch(err){
        svgContent = `<text x="4" y="12" fill="red" font-size="8">Error</text>`;
        hasError=true;
      }

      const card = document.createElement('div');
      card.className = 'preview-card';

      const wrap = document.createElement('div');
      wrap.className = 'preview-svg-wrap';
      wrap.style.width = sz.w+'px';
      wrap.style.height = sz.h+'px';

      const svgNS='http://www.w3.org/2000/svg';
      const svgEl=document.createElementNS(svgNS,'svg');
      svgEl.setAttribute('width',sz.w);svgEl.setAttribute('height',sz.h);
      svgEl.setAttribute('viewBox',`0 0 ${sz.w} ${sz.h}`);
      const g=document.createElementNS(svgNS,'g');
      g.innerHTML=svgContent;
      svgEl.appendChild(g);

      wrap.appendChild(svgEl);
      const lbl=document.createElement('div');
      lbl.className='preview-label';
      lbl.textContent=sz.label;
      card.appendChild(wrap);
      card.appendChild(lbl);
      area.appendChild(card);
    });
  });
  if(hasError) setStatus('⚠ Fehler im Code — Syntax prüfen');
  else setStatus('Vorschau aktualisiert · '+sizes.length+' Größen · '+PREVIEW_COLORS.slice(0,4).length+' Farben');
}

// ══════════════════════════════════════════════════════════
// EXPORT
// ══════════════════════════════════════════════════════════
function openExport(){
  const code = document.getElementById('code-input').value.trim();
  if(!code){ alert('Kein Code im Tester — zuerst zeichnen oder Code eingeben.'); return; }

  const id = document.getElementById('meta-id').value.trim() || 'neues-symbol';
  const name = document.getElementById('meta-name').value.trim() || 'Neues Symbol';
  const cat = document.getElementById('meta-cat').value;
  const w = parseFloat(document.getElementById('meta-w').value)||0.5;
  const h = parseFloat(document.getElementById('meta-h').value)||0.5;
  const scalable = document.getElementById('meta-scalable').value==='true';

  // Indent code nicely
  const indented = code.split('\n').map(l=>'      '+l.trim()).filter(l=>l.trim()).join('\n');

  const output = `  {
    id:'${id}', name:'${name}', cat:'${cat}',
    w:${w.toFixed(2)}, h:${h.toFixed(2)}, scalable:${scalable},
    draw:(c,pw,ph)=>\`
${indented}
    \`
  },`;

  document.getElementById('export-code').value = output;
  document.getElementById('export-modal').classList.remove('hidden');
}

function copyExport(){
  const ta = document.getElementById('export-code');
  ta.select();
  navigator.clipboard.writeText(ta.value).then(()=>setStatus('✓ In Zwischenablage kopiert'));
}

function closeExport(){
  document.getElementById('export-modal').classList.add('hidden');
}

document.getElementById('export-modal').addEventListener('click', e=>{
  if(e.target===document.getElementById('export-modal')) closeExport();
});

// ══════════════════════════════════════════════════════════
// LIBRARY RENDER
// ══════════════════════════════════════════════════════════
function renderLibrary(){
  const el = document.getElementById('tab-library');
  el.innerHTML='';
  const cats = {};
  SYMBOL_LIBRARY.forEach(sym=>{
    if(!cats[sym.cat]) cats[sym.cat]=[];
    cats[sym.cat].push(sym);
  });
  Object.keys(cats).forEach(cat=>{
    const info = LIB_CATS[cat]||{label:cat,icon:'◆'};
    const title = document.createElement('div');
    title.className='lib-section-title';
    title.textContent = info.icon+' '+info.label+' ('+cats[cat].length+')';
    el.appendChild(title);
    const grid=document.createElement('div');
    grid.className='lib-grid';
    cats[cat].forEach(sym=>{
      const card=document.createElement('div');
      card.className='lib-card';
      const previewW=64,previewH=64;
      const pColor='#4a90d9';
      const svgNS='http://www.w3.org/2000/svg';
      const svgEl=document.createElementNS(svgNS,'svg');
      svgEl.setAttribute('width',previewW);svgEl.setAttribute('height',previewH);
      svgEl.setAttribute('viewBox',`0 0 ${previewW} ${previewH}`);
      const bg=document.createElementNS(svgNS,'rect');
      bg.setAttribute('width',previewW);bg.setAttribute('height',previewH);bg.setAttribute('fill','white');
      svgEl.appendChild(bg);
      const g=document.createElementNS(svgNS,'g');
      try{g.innerHTML=sym.draw(pColor,previewW,previewH);}catch(e){}
      svgEl.appendChild(g);
      const name=document.createElement('div');name.className='lib-card-name';name.textContent=sym.name;
      const size=document.createElement('div');size.className='lib-card-size';size.textContent=sym.w+'×'+sym.h+'m';
      card.appendChild(svgEl);card.appendChild(name);card.appendChild(size);
      grid.appendChild(card);
    });
    el.appendChild(grid);
  });
}

// ══════════════════════════════════════════════════════════
// TABS
// ══════════════════════════════════════════════════════════
function switchTab(tab){
  document.querySelectorAll('.tab').forEach((t,i)=>{
    const names=['library','tester'];
    t.classList.toggle('active', names[i]===tab);
  });
  document.getElementById('tab-library').style.display = tab==='library'?'block':'none';
  document.getElementById('tab-tester').style.display = tab==='tester'?'flex':'none';
}

// ══════════════════════════════════════════════════════════
// STATUS
// ══════════════════════════════════════════════════════════
function setStatus(msg){ document.getElementById('status-msg').textContent=msg; }

// ══════════════════════════════════════════════════════════
// INIT
// ══════════════════════════════════════════════════════════
renderLibrary();
setTool('select');
setStatus('Bereit · Werkzeug wählen oder direkt zeichnen');
</script>
