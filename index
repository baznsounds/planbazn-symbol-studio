<!DOCTYPE html>
<html lang="de">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>PLANBAZN · Symbol Studio</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=DM+Mono:wght@400;500&family=Unbounded:wght@400;700;900&display=swap');

*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}

:root{
  --bg:#0a0a0f;
  --surface:#111118;
  --panel:#18181f;
  --panel2:#1e1e28;
  --border:#2a2a3a;
  --border2:#363648;
  --accent:#c8ff00;
  --accent2:#00d4ff;
  --accent3:#ff6b6b;
  --accent4:#b06aff;
  --text:#e8e8f0;
  --muted:#5a5a78;
  --muted2:#3a3a52;
  --font-ui:'Unbounded',sans-serif;
  --font-mono:'DM Mono',monospace;
  --grid:20px;
}

html,body{height:100%;overflow:hidden;background:var(--bg);color:var(--text);}
body{font-family:var(--font-mono);display:flex;flex-direction:column;}

/* ── HEADER ── */
#header{
  display:flex;align-items:center;gap:16px;
  padding:0 20px;height:48px;
  background:var(--surface);
  border-bottom:1px solid var(--border);
  flex-shrink:0;
}
#logo{
  font-family:var(--font-ui);font-size:11px;font-weight:900;
  letter-spacing:.15em;color:var(--accent);text-transform:uppercase;
  white-space:nowrap;
}
#logo span{color:var(--muted);font-weight:400;}
#header-sep{width:1px;height:24px;background:var(--border);flex-shrink:0;}
#header-info{font-size:9px;color:var(--muted);letter-spacing:.05em;}

/* ── LAYOUT ── */
#app{display:flex;flex:1;overflow:hidden;}

/* ── LEFT: DRAWER ── */
#drawer-panel{
  width:520px;flex-shrink:0;
  display:flex;flex-direction:column;
  border-right:1px solid var(--border);
  background:var(--surface);
}

/* Toolbar */
#tool-bar{
  display:flex;align-items:center;gap:4px;
  padding:8px 10px;
  border-bottom:1px solid var(--border);
  flex-shrink:0;flex-wrap:wrap;
}
.tool-group{display:flex;gap:3px;padding-right:8px;border-right:1px solid var(--border2);margin-right:4px;}
.tool-group:last-child{border-right:none;padding-right:0;margin-right:0;}
.tbtn{
  display:flex;align-items:center;justify-content:center;
  width:32px;height:32px;border-radius:6px;
  border:1px solid var(--border);background:var(--panel);
  color:var(--muted);font-size:14px;cursor:pointer;
  transition:all .12s;flex-shrink:0;
}
.tbtn:hover{border-color:var(--border2);color:var(--text);}
.tbtn.active{background:var(--accent);border-color:var(--accent);color:#000;}
.tbtn.danger:hover{border-color:var(--accent3);color:var(--accent3);}
.tbtn[title]{position:relative;}

/* Canvas area */
#canvas-area{
  flex:1;overflow:hidden;
  display:flex;align-items:center;justify-content:center;
  background:var(--bg);
  background-image:
    linear-gradient(var(--border2) 1px, transparent 1px),
    linear-gradient(90deg, var(--border2) 1px, transparent 1px);
  background-size:var(--grid) var(--grid);
  position:relative;
}
#canvas-wrap{
  position:relative;
  box-shadow:0 0 0 1px var(--border2), 0 8px 48px rgba(0,0,0,.6);
}
#draw-svg{
  display:block;
  background:#fff;
  cursor:crosshair;
}
#draw-svg.select-mode{cursor:default;}

/* Properties panel */
#props-panel{
  flex-shrink:0;
  border-top:1px solid var(--border);
  background:var(--panel);
  padding:10px 12px;
  display:flex;flex-direction:column;gap:8px;
}
#props-title{font-size:8px;font-weight:500;color:var(--muted);letter-spacing:.1em;text-transform:uppercase;}
#props-rows{display:flex;flex-wrap:wrap;gap:8px;}
.prop-row{display:flex;align-items:center;gap:6px;flex-shrink:0;}
.prop-label{font-size:9px;color:var(--muted);white-space:nowrap;min-width:60px;}
.prop-val{font-size:10px;color:var(--accent2);font-weight:500;min-width:32px;}
input[type=range].prop-slider{
  -webkit-appearance:none;appearance:none;
  width:100px;height:3px;background:var(--border2);border-radius:2px;outline:none;cursor:pointer;
}
input[type=range].prop-slider::-webkit-slider-thumb{
  -webkit-appearance:none;width:12px;height:12px;border-radius:50%;
  background:var(--accent2);cursor:pointer;
}
.prop-color-row{display:flex;gap:4px;flex-wrap:wrap;}
.prop-swatch{
  width:20px;height:20px;border-radius:4px;cursor:pointer;
  border:2px solid transparent;transition:border-color .1s;flex-shrink:0;
}
.prop-swatch.sel{border-color:#fff;}
.prop-swatch:hover{border-color:rgba(255,255,255,.5);}

/* ── RIGHT: LIBRARY & TESTER ── */
#right-panel{
  flex:1;display:flex;flex-direction:column;overflow:hidden;
  background:var(--bg);
}

/* Tabs */
#tabs{
  display:flex;border-bottom:1px solid var(--border);
  background:var(--surface);flex-shrink:0;
}
.tab{
  padding:10px 20px;font-size:9px;font-weight:500;
  letter-spacing:.08em;text-transform:uppercase;
  color:var(--muted);cursor:pointer;border-bottom:2px solid transparent;
  transition:all .12s;
}
.tab:hover{color:var(--text);}
.tab.active{color:var(--accent);border-bottom-color:var(--accent);}

#tab-content{flex:1;overflow:hidden;display:flex;flex-direction:column;}

/* ── TAB: LIBRARY ── */
#tab-library{flex:1;overflow-y:auto;padding:12px;}
#tab-library::-webkit-scrollbar{width:4px;}
#tab-library::-webkit-scrollbar-thumb{background:var(--border);border-radius:2px;}
.lib-section-title{
  font-size:8px;font-weight:500;letter-spacing:.1em;text-transform:uppercase;
  color:var(--muted);padding:8px 4px 6px;
  display:flex;align-items:center;gap:8px;
}
.lib-section-title::after{content:'';flex:1;height:1px;background:var(--border);}
.lib-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(80px,1fr));gap:6px;margin-bottom:8px;}
.lib-card{
  background:var(--panel);border:1px solid var(--border);border-radius:8px;
  padding:8px 4px 5px;cursor:default;
  display:flex;flex-direction:column;align-items:center;gap:3px;
  transition:border-color .12s;
}
.lib-card:hover{border-color:var(--border2);}
.lib-card svg{display:block;}
.lib-card-name{font-size:7px;color:var(--muted);text-align:center;line-height:1.3;width:100%;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;}
.lib-card-size{font-size:6px;color:var(--muted2);}

/* ── TAB: TESTER ── */
#tab-tester{flex:1;display:flex;flex-direction:column;overflow:hidden;}

#tester-top{
  flex-shrink:0;padding:12px;border-bottom:1px solid var(--border);
  display:flex;flex-direction:column;gap:8px;background:var(--surface);
}
#tester-top-title{font-size:8px;color:var(--muted);letter-spacing:.1em;text-transform:uppercase;}

#code-input{
  width:100%;height:140px;resize:none;
  background:var(--panel);border:1px solid var(--border);border-radius:6px;
  padding:10px;color:var(--text);font-family:var(--font-mono);font-size:10px;
  outline:none;line-height:1.6;
}
#code-input:focus{border-color:var(--accent2);}
#code-input::placeholder{color:var(--muted2);}

#meta-row{display:flex;gap:8px;flex-wrap:wrap;}
.meta-field{display:flex;flex-direction:column;gap:3px;flex:1;min-width:80px;}
.meta-label{font-size:8px;color:var(--muted);letter-spacing:.06em;}
.meta-input{
  background:var(--panel);border:1px solid var(--border);border-radius:5px;
  padding:5px 8px;color:var(--text);font-family:var(--font-mono);font-size:10px;
  outline:none;width:100%;
}
.meta-input:focus{border-color:var(--accent2);}
select.meta-input option{background:var(--panel);}

#tester-actions{display:flex;gap:6px;}
.action-btn{
  padding:6px 14px;border-radius:6px;border:1px solid var(--border);
  background:var(--panel);color:var(--text);font-family:var(--font-mono);
  font-size:9px;font-weight:500;cursor:pointer;letter-spacing:.05em;
  transition:all .12s;white-space:nowrap;
}
.action-btn:hover{border-color:var(--border2);color:var(--accent);}
.action-btn.primary{background:var(--accent);border-color:var(--accent);color:#000;font-weight:700;}
.action-btn.primary:hover{background:#d4ff10;}
.action-btn.export{background:var(--accent4);border-color:var(--accent4);color:#fff;font-weight:700;}
.action-btn.export:hover{background:#c080ff;}

#tester-bottom{flex:1;overflow:hidden;display:flex;flex-direction:column;}

#preview-area{
  flex:1;display:flex;align-items:center;justify-content:center;
  background:var(--bg);
  background-image:radial-gradient(circle at 1px 1px, var(--border2) 1px, transparent 0);
  background-size:16px 16px;
  padding:16px;gap:12px;flex-wrap:wrap;overflow-y:auto;
}

.preview-card{
  display:flex;flex-direction:column;align-items:center;gap:6px;
}
.preview-label{font-size:8px;color:var(--muted);text-align:center;}
.preview-svg-wrap{
  background:#fff;border-radius:4px;
  box-shadow:0 2px 12px rgba(0,0,0,.4);
  display:flex;align-items:center;justify-content:center;
  overflow:hidden;
}

/* ── EXPORT MODAL ── */
#export-modal{
  position:fixed;inset:0;background:rgba(0,0,0,.8);
  display:flex;align-items:center;justify-content:center;
  z-index:1000;backdrop-filter:blur(6px);
}
#export-modal.hidden{display:none;}
#export-box{
  background:var(--surface);border:1px solid var(--border);border-radius:12px;
  padding:20px;width:600px;max-width:95vw;
  display:flex;flex-direction:column;gap:12px;
}
#export-box h3{font-family:var(--font-ui);font-size:11px;color:var(--accent);letter-spacing:.1em;}
#export-code{
  width:100%;height:220px;resize:none;
  background:var(--panel);border:1px solid var(--border);border-radius:6px;
  padding:10px;color:var(--accent2);font-family:var(--font-mono);font-size:10px;
  outline:none;line-height:1.7;
}
#export-actions{display:flex;gap:8px;justify-content:flex-end;}

/* ── STATUS BAR ── */
#statusbar{
  height:24px;padding:0 14px;
  display:flex;align-items:center;gap:12px;
  background:var(--surface);border-top:1px solid var(--border);
  font-size:8px;color:var(--muted);flex-shrink:0;
  letter-spacing:.05em;
}
#status-msg{color:var(--accent2);}

/* ── SCROLLBAR ── */
::-webkit-scrollbar{width:4px;height:4px;}
::-webkit-scrollbar-track{background:transparent;}
::-webkit-scrollbar-thumb{background:var(--border);border-radius:2px;}
</style>
</head>
<body>

<div id="header">
  <div id="logo">PLANBAZN <span>·</span> Symbol Studio</div>
  <div id="header-sep"></div>
  <div id="header-info">SVG Drawer &amp; Library Tester</div>
</div>

<div id="app">

  <!-- ══ LEFT: DRAWER ══ -->
  <div id="drawer-panel">

    <div id="tool-bar">
      <div class="tool-group">
        <button class="tbtn active" id="tool-select" title="Auswahl (V)" onclick="setTool('select')">↖</button>
      </div>
      <div class="tool-group">
        <button class="tbtn" id="tool-line" title="Linie (L)" onclick="setTool('line')">╱</button>
        <button class="tbtn" id="tool-rect" title="Rechteck (R)" onclick="setTool('rect')">▭</button>
        <button class="tbtn" id="tool-circle" title="Kreis/Ellipse (C)" onclick="setTool('circle')">○</button>
        <button class="tbtn" id="tool-poly" title="Polygon (P) — Klicken für Punkte, Doppelklick zum Abschließen" onclick="setTool('poly')">⬡</button>
      </div>
      <div class="tool-group">
        <button class="tbtn danger" title="Auswahl löschen (Del)" onclick="deleteSelected()">🗑</button>
        <button class="tbtn danger" title="Alles löschen" onclick="clearCanvas()">✕</button>
      </div>
      <div class="tool-group">
        <button class="tbtn" title="Rückgängig (Ctrl+Z)" onclick="undo()">↩</button>
      </div>
      <div class="tool-group" style="margin-left:auto;border-right:none;">
        <button class="tbtn" title="An Tester senden" onclick="sendToTester()" style="width:auto;padding:0 10px;font-size:9px;color:var(--accent);">→ Testen</button>
      </div>
    </div>

    <div id="canvas-area">
      <div id="canvas-wrap">
        <svg id="draw-svg" width="400" height="400" viewBox="0 0 100 100"
          xmlns="http://www.w3.org/2000/svg">
          <!-- grid lines -->
          <defs>
            <pattern id="smallgrid" width="5" height="5" patternUnits="userSpaceOnUse">
              <path d="M 5 0 L 0 0 0 5" fill="none" stroke="#e0e0e0" stroke-width="0.15"/>
            </pattern>
            <pattern id="grid" width="10" height="10" patternUnits="userSpaceOnUse">
              <rect width="10" height="10" fill="url(#smallgrid)"/>
              <path d="M 10 0 L 0 0 0 10" fill="none" stroke="#d0d0d0" stroke-width="0.3"/>
            </pattern>
          </defs>
          <rect width="100" height="100" fill="white"/>
          <rect width="100" height="100" fill="url(#grid)"/>
          <!-- border -->
          <rect x="0" y="0" width="100" height="100" fill="none" stroke="#bbb" stroke-width="0.5"/>
          <g id="objects-layer"></g>
          <g id="temp-layer"></g>
          <g id="select-layer"></g>
        </svg>
      </div>
    </div>

    <div id="props-panel">
      <div id="props-title">Eigenschaften</div>
      <div id="props-rows">
        <!-- Stroke width -->
        <div class="prop-row">
          <span class="prop-label">Strichstärke</span>
          <input type="range" class="prop-slider" id="prop-sw" min="0.3" max="4" step="0.1" value="1.5"
            oninput="updateStrokeWidth(this.value)">
          <span class="prop-val" id="prop-sw-val">1.5</span>
        </div>
        <!-- Corner radius -->
        <div class="prop-row">
          <span class="prop-label">Eckenradius</span>
          <input type="range" class="prop-slider" id="prop-rx" min="0" max="20" step="0.5" value="0"
            oninput="updateCornerRadius(this.value)">
          <span class="prop-val" id="prop-rx-val">0</span>
        </div>
        <!-- Fill opacity -->
        <div class="prop-row">
          <span class="prop-label">Füllung %</span>
          <input type="range" class="prop-slider" id="prop-fill" min="0" max="100" step="5" value="15"
            oninput="updateFillOpacity(this.value)">
          <span class="prop-val" id="prop-fill-val">15%</span>
        </div>
        <!-- Colors -->
        <div class="prop-row" style="width:100%;">
          <span class="prop-label">Farbe</span>
          <div class="prop-color-row" id="prop-colors"></div>
        </div>
      </div>
    </div>

  </div>

  <!-- ══ RIGHT PANEL ══ -->
  <div id="right-panel">
    <div id="tabs">
      <div class="tab active" onclick="switchTab('library')">📦 Bibliothek</div>
      <div class="tab" onclick="switchTab('tester')">🧪 Tester</div>
    </div>

    <div id="tab-content">

      <!-- LIBRARY TAB -->
      <div id="tab-library"></div>

      <!-- TESTER TAB -->
      <div id="tab-tester" style="display:none;">
        <div id="tester-top">
          <div id="tester-top-title">Symbol Code → Live Vorschau</div>
          <textarea id="code-input" spellcheck="false"
            placeholder="Füge hier den draw-Funktions-Body ein, z.B.:&#10;&#10;&lt;rect x=&quot;2&quot; y=&quot;2&quot; width=&quot;${pw-4}&quot; height=&quot;${ph-4}&quot; rx=&quot;4&quot; fill=&quot;${c}22&quot; stroke=&quot;${c}&quot; stroke-width=&quot;1.5&quot;/&gt;&#10;&#10;Variablen: c (Farbe), pw (Breite px), ph (Höhe px)"
            oninput="schedulePreview()"></textarea>
          <div id="meta-row">
            <div class="meta-field">
              <span class="meta-label">ID</span>
              <input type="text" class="meta-input" id="meta-id" placeholder="z.B. lautsprecher-15">
            </div>
            <div class="meta-field">
              <span class="meta-label">Name</span>
              <input type="text" class="meta-input" id="meta-name" placeholder="z.B. Lautsprecher 15″">
            </div>
            <div class="meta-field" style="max-width:120px;">
              <span class="meta-label">Kategorie</span>
              <select class="meta-input" id="meta-cat">
                <option value="generic">Generic</option>
                <option value="rigging">Rigging</option>
                <option value="multimedia">Multimedia</option>
                <option value="audio">Audio</option>
                <option value="light">Light</option>
                <option value="stage">Stage</option>
                <option value="furniture">Furniture</option>
                <option value="power">Power</option>
              </select>
            </div>
            <div class="meta-field" style="max-width:70px;">
              <span class="meta-label">Breite (m)</span>
              <input type="number" class="meta-input" id="meta-w" value="0.5" min="0.1" step="0.05">
            </div>
            <div class="meta-field" style="max-width:70px;">
              <span class="meta-label">Höhe (m)</span>
              <input type="number" class="meta-input" id="meta-h" value="0.5" min="0.1" step="0.05">
            </div>
            <div class="meta-field" style="max-width:90px;">
              <span class="meta-label">Skalierbar</span>
              <select class="meta-input" id="meta-scalable">
                <option value="false">Nein</option>
                <option value="true">Ja</option>
              </select>
            </div>
          </div>
          <div id="tester-actions">
            <button class="action-btn" onclick="schedulePreview()">▶ Vorschau</button>
            <button class="action-btn" onclick="loadFromDrawer()">← Vom Drawer laden</button>
            <button class="action-btn export" onclick="openExport()">↗ Code exportieren</button>
          </div>
        </div>
        <div id="tester-bottom">
          <div id="preview-area"></div>
        </div>
      </div>

    </div>
  </div>
</div>

<!-- EXPORT MODAL -->
<div id="export-modal" class="hidden">
  <div id="export-box">
    <h3>↗ PLANBAZN SYMBOL CODE</h3>
    <textarea id="export-code" readonly spellcheck="false"></textarea>
    <div id="export-actions">
      <button class="action-btn" onclick="copyExport()">📋 Kopieren</button>
      <button class="action-btn" onclick="closeExport()">✕ Schließen</button>
    </div>
  </div>
</div>

<div id="statusbar">
  <span id="status-msg">Bereit</span>
  <span style="margin-left:auto;">Zeichenfläche: 100×100 · Snap: 0.5</span>
</div>

<script>
// ══════════════════════════════════════════════════════════
// SYMBOL LIBRARY (from PLANBAZN)
// ══════════════════════════════════════════════════════════
const SYMBOL_LIBRARY = [
  {
    id:'generic-rect', name:'Rechteck', cat:'generic',
    w:2.00, h:1.00, scalable:true,
    draw:(c,pw,ph)=>`
      <rect x="2" y="2" width="${pw-4}" height="${ph-4}" rx="0" fill="${c}22" stroke="${c}" stroke-width="2"/>
    `
  },
  {
    id:'generic-circle', name:'Kreis', cat:'generic',
    w:1.00, h:1.00, scalable:true,
    draw:(c,pw,ph)=>`
      <ellipse cx="${pw/2}" cy="${ph/2}" rx="${pw/2-2}" ry="${ph/2-2}" fill="${c}22" stroke="${c}" stroke-width="2"/>
    `
  },
  {
    id:'generic-triangle', name:'Dreieck', cat:'generic',
    w:1.00, h:1.00, scalable:true,
    draw:(c,pw,ph)=>`
      <polygon points="${pw/2},2 ${pw-2},${ph-2} 2,${ph-2}" fill="${c}22" stroke="${c}" stroke-width="2"/>
    `
  },
  {
    id:'traverse', name:'Traverse', cat:'rigging',
    w:2.00, h:0.29, scalable:true,
    draw:(c,pw,ph)=>{
      const topY=ph*0.12, botY=ph*0.88;
      const n=Math.max(1,Math.round(pw/(ph*1.5)));
      let diags='';
      for(let i=0;i<n;i++){
        const x0=pw*i/n, x1=pw*(i+1)/n;
        diags+=`<line x1="${x0}" y1="${topY}" x2="${x1}" y2="${botY}" stroke="${c}" stroke-width="1.2"/>`;
        diags+=`<line x1="${x0}" y1="${botY}" x2="${x1}" y2="${topY}" stroke="${c}" stroke-width="1.2"/>`;
      }
      return `
        <rect x="0" y="0" width="${pw}" height="${ph}" fill="${c}10" stroke="none"/>
        <line x1="0" y1="${topY}" x2="${pw}" y2="${topY}" stroke="${c}" stroke-width="2"/>
        <line x1="0" y1="${botY}" x2="${pw}" y2="${botY}" stroke="${c}" stroke-width="2"/>
        ${diags}
      `;
    }
  },
  {
    id:'haengepunkt', name:'Hängepunkt', cat:'rigging',
    w:0.50, h:0.50, scalable:false,
    draw:(c,pw,ph)=>{
      const cx=pw/2, cy=ph/2, r=Math.min(pw,ph)*0.38;
      return `
        <line x1="${cx}" y1="0" x2="${cx}" y2="${ph}" stroke="${c}" stroke-width="1.8"/>
        <line x1="0" y1="${cy}" x2="${pw}" y2="${cy}" stroke="${c}" stroke-width="1.8"/>
        <circle cx="${cx}" cy="${cy}" r="${r}" fill="none" stroke="${c}" stroke-width="1.8"/>
        <path d="M${cx},${cy} L${cx+r},${cy} A${r},${r} 0 0,1 ${cx},${cy+r} Z" fill="${c}" stroke="none"/>
        <path d="M${cx},${cy} L${cx-r},${cy} A${r},${r} 0 0,1 ${cx},${cy-r} Z" fill="${c}" stroke="none"/>
      `;
    }
  },
  {
    id:'flatscreen-75', name:'Flatscreen 75"', cat:'multimedia',
    w:1.00, h:1.00, scalable:false,
    draw:(c,pw,ph)=>{
      const smallW=pw*0.29, smallH=ph*0.29;
      const smallX=(pw-smallW)/2, smallY=(ph-smallH)/2;
      const barW=pw*1.7, barH=ph*0.05;
      const barX=(pw-barW)/2, barY=smallY+smallH;
