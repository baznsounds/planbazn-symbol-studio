// ══════════════════════════════════════════════════════════
// SVG ELEMENT CREATION
// ══════════════════════════════════════════════════════════
function mkEl(tag, attrs){
  const el = document.createElementNS('http://www.w3.org/2000/svg', tag);
  Object.entries(attrs).forEach(([k,v])=>el.setAttribute(k,v));
  return el;
}

function applyStyle(el, stroke, fillOpacity, sw, rx){
  el.setAttribute('stroke', stroke);
  el.setAttribute('stroke-width', sw);
  el.setAttribute('fill', fillOpacity > 0 ? stroke : 'none');
  if(fillOpacity > 0) el.setAttribute('fill-opacity', fillOpacity);
  else el.setAttribute('fill', 'none');
  if(rx !== undefined && rx > 0){
    el.setAttribute('rx', rx);
    el.setAttribute('ry', rx);
  }
}

// ── Rounded polygon path using cubic beziers ──
function roundedPolygonPath(pts, r){
  if(pts.length < 2) return '';
  if(r <= 0 || pts.length === 2){
    // Simple line or no rounding
    return pts.map((p,i)=>(i===0?`M${p.x},${p.y}`:`L${p.x},${p.y}`)).join(' ') + (pts.length>2?' Z':'');
  }
  const n = pts.length;
  let d = '';
  for(let i=0;i<n;i++){
    const prev = pts[(i-1+n)%n];
    const curr = pts[i];
    const next = pts[(i+1)%n];
    // vectors
    const d1x = curr.x - prev.x, d1y = curr.y - prev.y;
    const d2x = next.x - curr.x, d2y = next.y - curr.y;
    const len1 = Math.hypot(d1x, d1y);
    const len2 = Math.hypot(d2x, d2y);
    if(len1===0||len2===0){d+=`${i===0?'M':'L'}${curr.x},${curr.y} `;continue;}
    // clamp radius to half of shortest adjacent segment
    const rr = Math.min(r, len1/2, len2/2);
    // tangent points
    const t1x = curr.x - (d1x/len1)*rr, t1y = curr.y - (d1y/len1)*rr;
    const t2x = curr.x + (d2x/len2)*rr, t2y = curr.y + (d2y/len2)*rr;
    if(i===0) d+=`M${t1x.toFixed(2)},${t1y.toFixed(2)} `;
    else d+=`L${t1x.toFixed(2)},${t1y.toFixed(2)} `;
    // quadratic bezier through corner
    d+=`Q${curr.x},${curr.y} ${t2x.toFixed(2)},${t2y.toFixed(2)} `;
  }
  d += 'Z';
  return d;
}

// ══════════════════════════════════════════════════════════
// OBJECT STORAGE
// ══════════════════════════════════════════════════════════
let objIdCounter = 0;

function addObject(type, data){
  undoStack.push(JSON.parse(JSON.stringify(objects)));
  if(undoStack.length > 30) undoStack.shift();
  const id = ++objIdCounter;
  const obj = {id, type, color:activeColor, sw:currentProps.sw, rx:currentProps.rx, fillOpacity:currentProps.fillOpacity, ...data};
  objects.push(obj);
  renderObject(obj);
  return obj;
}

function renderObject(obj){
  // remove old element if exists
  const old = document.getElementById('obj-'+obj.id);
  if(old) old.remove();

  let el;
  if(obj.type==='line'){
    el = mkEl('line',{x1:obj.x1,y1:obj.y1,x2:obj.x2,y2:obj.y2,stroke:obj.color,'stroke-width':obj.sw,fill:'none','stroke-linecap':'round'});
  } else if(obj.type==='rect'){
    const x=Math.min(obj.x1,obj.x2), y=Math.min(obj.y1,obj.y2);
    const w=Math.abs(obj.x2-obj.x1), h=Math.abs(obj.y2-obj.y1);
    el = mkEl('rect',{x,y,width:w,height:h});
    applyStyle(el, obj.color, obj.fillOpacity, obj.sw, obj.rx);
  } else if(obj.type==='circle'){
    const cx=(obj.x1+obj.x2)/2, cy=(obj.y1+obj.y2)/2;
    const rx=Math.abs(obj.x2-obj.x1)/2, ry=Math.abs(obj.y2-obj.y1)/2;
    el = mkEl('ellipse',{cx,cy,rx,ry});
    applyStyle(el, obj.color, obj.fillOpacity, obj.sw);
  } else if(obj.type==='poly'){
    const d = roundedPolygonPath(obj.pts, obj.rx);
    el = mkEl('path',{d});
    applyStyle(el, obj.color, obj.fillOpacity, obj.sw);
    el.setAttribute('stroke-linejoin','round');
    el.setAttribute('stroke-linecap','round');
  }

  if(!el) return;
  el.id = 'obj-'+obj.id;
  el.dataset.oid = obj.id;
  el.style.cursor = 'pointer';
  objectsLayer.appendChild(el);
  updateSelection();
}

function redrawAll(){
  objectsLayer.innerHTML='';
  objects.forEach(o=>renderObject(o));
}

// ══════════════════════════════════════════════════════════
// SELECTION
// ══════════════════════════════════════════════════════════
function selectObject(id){
  selectedId = id;
  updateSelection();
  if(id){
    const obj = objects.find(o=>o.id===id);
    if(obj){
      // sync props panel to selected object
      document.getElementById('prop-sw').value = obj.sw;
      document.getElementById('prop-sw-val').textContent = obj.sw;
      document.getElementById('prop-rx').value = obj.rx;
      document.getElementById('prop-rx-val').textContent = obj.rx;
      document.getElementById('prop-fill').value = Math.round(obj.fillOpacity*100);
      document.getElementById('prop-fill-val').textContent = Math.round(obj.fillOpacity*100)+'%';
      activeColor = obj.color;
      document.querySelectorAll('.prop-swatch').forEach(s=>{
        s.classList.toggle('sel', s.style.background===activeColor||rgbToHex(s.style.background)===activeColor);
      });
    }
  }
}

function rgbToHex(rgb){
  const m = rgb.match(/rgb\((\d+),\s*(\d+),\s*(\d+)\)/);
  if(!m) return rgb;
  return '#'+ [m[1],m[2],m[3]].map(x=>parseInt(x).toString(16).padStart(2,'0')).join('');
}

function updateSelection(){
  selectLayer.innerHTML='';
  if(!selectedId) return;
  const obj = objects.find(o=>o.id===selectedId);
  if(!obj) return;
  let bb;
  if(obj.type==='line'){
    bb={x:Math.min(obj.x1,obj.x2)-1,y:Math.min(obj.y1,obj.y2)-1,w:Math.abs(obj.x2-obj.x1)+2,h:Math.abs(obj.y2-obj.y1)+2};
  } else if(obj.type==='rect'){
    bb={x:Math.min(obj.x1,obj.x2)-1,y:Math.min(obj.y1,obj.y2)-1,w:Math.abs(obj.x2-obj.x1)+2,h:Math.abs(obj.y2-obj.y1)+2};
  } else if(obj.type==='circle'){
    const rx=Math.abs(obj.x2-obj.x1)/2, ry=Math.abs(obj.y2-obj.y1)/2;
    const cx=(obj.x1+obj.x2)/2, cy=(obj.y1+obj.y2)/2;
    bb={x:cx-rx-1,y:cy-ry-1,w:rx*2+2,h:ry*2+2};
  } else if(obj.type==='poly'){
    const xs=obj.pts.map(p=>p.x), ys=obj.pts.map(p=>p.y);
    const minX=Math.min(...xs), minY=Math.min(...ys);
    bb={x:minX-1,y:minY-1,w:Math.max(...xs)-minX+2,h:Math.max(...ys)-minY+2};
  }
  if(!bb) return;
  const sel = mkEl('rect',{x:bb.x,y:bb.y,width:bb.w,height:bb.h,fill:'none',stroke:'#00d4ff','stroke-width':0.4,'stroke-dasharray':'2 1',rx:0.5,ry:0.5,'pointer-events':'none'});
  selectLayer.appendChild(sel);
}

function deleteSelected(){
  if(!selectedId) return;
  undoStack.push(JSON.parse(JSON.stringify(objects)));
  objects = objects.filter(o=>o.id!==selectedId);
  const el = document.getElementById('obj-'+selectedId);
  if(el) el.remove();
  selectedId = null;
  selectLayer.innerHTML='';
}

function clearCanvas(){
  if(!objects.length) return;
  if(!confirm('Zeichenfläche leeren?')) return;
  undoStack.push(JSON.parse(JSON.stringify(objects)));
  objects=[];
  objectsLayer.innerHTML='';
  selectLayer.innerHTML='';
  selectedId=null;
}

function undo(){
  if(!undoStack.length){setStatus('Nichts rückgängig zu machen');return;}
  objects = undoStack.pop();
  redrawAll();
  selectedId=null;
  selectLayer.innerHTML='';
}

// ══════════════════════════════════════════════════════════
// PROPERTY UPDATES
// ══════════════════════════════════════════════════════════
function updateStrokeWidth(v){
  currentProps.sw = parseFloat(v);
  document.getElementById('prop-sw-val').textContent = v;
  if(selectedId){
    const obj=objects.find(o=>o.id===selectedId);
    if(obj){obj.sw=parseFloat(v);renderObject(obj);}
  }
}
function updateCornerRadius(v){
  currentProps.rx = parseFloat(v);
  document.getElementById('prop-rx-val').textContent = v;
  if(selectedId){
    const obj=objects.find(o=>o.id===selectedId);
    if(obj){obj.rx=parseFloat(v);renderObject(obj);}
  }
}
function updateFillOpacity(v){
  currentProps.fillOpacity = parseInt(v)/100;
  document.getElementById('prop-fill-val').textContent = v+'%';
  if(selectedId){
    const obj=objects.find(o=>o.id===selectedId);
