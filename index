// ══════════════════════════════════════════════════════════
// COORDINATE HELPERS
// ══════════════════════════════════════════════════════════
function svgPos(e){
  const r = drawSvg.getBoundingClientRect();
  const scaleX = 100 / r.width;
  const scaleY = 100 / r.height;
  const raw = {
    x: (e.clientX - r.left) * scaleX,
    y: (e.clientY - r.top) * scaleY
  };
  return {
    x: Math.max(0, Math.min(100, Math.round(raw.x / SNAP) * SNAP)),
    y: Math.max(0, Math.min(100, Math.round(raw.y / SNAP) * SNAP))
  };
}

